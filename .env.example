# HelaService Environment Configuration
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!

# ============================================
# PayHere Configuration (Sri Lanka Payments)
# ============================================
# Get these from your PayHere merchant account
PAYHERE_MERCHANT_ID=your_merchant_id_here
PAYHERE_MERCHANT_SECRET=your_merchant_secret_here

# Set to true for sandbox/testing, false for production
PAYHERE_SANDBOX=true

# Backend webhook URL (Cloud Function URL)
# This will be auto-generated after deploying Firebase Functions
PAYHERE_NOTIFY_URL=https://us-central1-helaservice-prod.cloudfunctions.net/payhereNotify
