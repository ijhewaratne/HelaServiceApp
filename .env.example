# HelaService Environment Configuration
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git!

# ============================================
# FIREBASE CONFIGURATION
# ============================================
# Get these from Firebase Console > Project Settings > General > Your apps
# Android app
FIREBASE_API_KEY_ANDROID=your_android_api_key_here
FIREBASE_APP_ID_ANDROID=1:919789688280:android:your_app_id

# iOS app
FIREBASE_API_KEY_IOS=your_ios_api_key_here
FIREBASE_APP_ID_IOS=1:919789688280:ios:your_app_id

# Web app
FIREBASE_API_KEY_WEB=your_web_api_key_here
FIREBASE_APP_ID_WEB=1:919789688280:web:your_app_id

# Shared Firebase settings
FIREBASE_PROJECT_ID=helaservice-prod
FIREBASE_MESSAGING_SENDER_ID=919789688280
FIREBASE_STORAGE_BUCKET=helaservice-prod.firebasestorage.app
FIREBASE_AUTH_DOMAIN=helaservice-prod.firebaseapp.com
FIREBASE_MEASUREMENT_ID=G-your_measurement_id
FIREBASE_IOS_BUNDLE_ID=com.example.homeServiceApp

# ============================================
# ENCRYPTION KEYS (PDPA Compliance)
# ============================================
# Generate a strong 32+ character key for AES encryption
# Use: openssl rand -base64 32
ENCRYPTION_KEY=your_32_character_encryption_key_here!!!

# ============================================
# PAYMENT CONFIGURATION (PayHere)
# ============================================
# Get from PayHere Merchant Dashboard
PAYHERE_MERCHANT_ID=your_merchant_id
PAYHERE_MERCHANT_SECRET=your_merchant_secret
PAYHERE_NOTIFY_URL=https://your-cloud-function-url/payhereNotify
PAYHERE_SANDBOX=true

# ============================================
# API KEYS
# ============================================
# Google Maps API Key (from Google Cloud Console)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# ============================================
# APP CONFIGURATION
# ============================================
# Environment: development, staging, production
ENVIRONMENT=development

# API Base URL (for custom backend if any)
API_BASE_URL=https://api.helaservice.lk

# ============================================
# SECURITY
# ============================================
# Enable/disable debug features
DEBUG_MODE=true
ENABLE_ANALYTICS=true
ENABLE_CRASHLYTICS=true

# ============================================
# CONTACT INFORMATION
# ============================================
SUPPORT_EMAIL=support@helaservice.lk
SUPPORT_PHONE=+94 11 234 5678
EMERGENCY_WHATSAPP=+94 77 123 4567
