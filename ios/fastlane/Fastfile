default_platform(:ios)

platform :ios do
  desc "Run tests"
  lane :test do
    scan(
      scheme: "Runner",
      devices: ["iPhone 14"]
    )
  end

  desc "Build iOS app"
  lane :build do
    gym(
      scheme: "Runner",
      export_method: "app-store",
      output_directory: "build/ios",
      output_name: "HelaService.ipa"
    )
  end

  desc "Build ad-hoc for testing"
  lane :build_adhoc do
    gym(
      scheme: "Runner",
      export_method: "ad-hoc",
      output_directory: "build/ios",
      output_name: "HelaService-AdHoc.ipa"
    )
  end

  desc "Upload to TestFlight (Beta)"
  lane :deploy_beta do
    build
    
    pilot(
      app_identifier: "com.helaservice.app",
      skip_waiting_for_build_processing: true,
      distribute_external: false,
      changelog: File.read("../../CHANGELOG.md").lines.first(10).join
    )
  end

  desc "Upload to App Store (Production)"
  lane :deploy_production do
    build
    
    deliver(
      submit_for_review: true,
      automatic_release: false,
      force: true,
      skip_metadata: false,
      skip_screenshots: false,
      skip_binary_metadata: false
    )
  end

  desc "Increment build number"
  lane :increment_build do
    increment_build_number(xcodeproj: "Runner.xcodeproj")
  end

  desc "Increment version number"
  lane :increment_version do |options|
    increment_version_number(
      xcodeproj: "Runner.xcodeproj",
      version_number: options[:version]
    )
  end

  desc "Sync signing certificates"
  lane :sync_certs do
    match(type: "appstore")
    match(type: "development")
  end
end
