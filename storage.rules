rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // =========================================================================
    // WORKER DOCUMENTS (PDPA Critical — encrypted at rest)
    // =========================================================================
    match /workers/{workerId}/{fileName} {
      // Only the worker themselves can read/write their own documents
      allow read, write: if request.auth != null && request.auth.uid == workerId;

      // File size limit: 5MB for NIC images, 2MB for profile photos
      allow write: if request.auth != null
        && request.auth.uid == workerId
        && request.resource.size <= 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // =========================================================================
    // ADMIN — can read all worker documents for verification
    // =========================================================================
    match /workers/{workerId}/{fileName} {
      allow read: if request.auth != null && request.auth.token.admin == true;
    }

    // =========================================================================
    // PROFILE PHOTOS — public read for active workers only
    // The 'profile.jpg' path is publicly readable to allow customer trust badges.
    // All other files (/nic_front, /nic_back) remain private.
    // =========================================================================
    match /workers/{workerId}/profile.jpg {
      allow read: if request.auth != null;
    }

    // =========================================================================
    // DENY ALL ELSE
    // =========================================================================
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
